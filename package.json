{
  "name": "agentharbor",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time observability platform for distributed AI coding agents.",
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "setup:agent": "bash scripts/agentic-setup.sh",
    "build:packages": "pnpm --filter './packages/**' build",
    "build": "pnpm -r --filter './packages/**' --filter './apps/**' build",
    "dev:control": "pnpm build:packages && bash scripts/with-root-env.sh pnpm --filter @agentharbor/control-node dev",
    "dev:dashboard": "pnpm build:packages && bash scripts/with-root-env.sh pnpm --filter @agentharbor/dashboard dev",
    "dev:runner": "pnpm --filter @agentharbor/runner dev",
    "db:generate": "bash scripts/with-root-env.sh pnpm --filter @agentharbor/control-node prisma generate",
    "db:push": "bash scripts/with-root-env.sh pnpm --filter @agentharbor/control-node prisma db push",
    "demo:reset": "pnpm --filter @agentharbor/control-node exec tsx scripts/demo-reset.ts",
    "demo:seed": "pnpm --filter @agentharbor/control-node exec tsx scripts/demo-seed.ts",
    "demo:burst": "pnpm --filter @agentharbor/control-node exec tsx scripts/demo-burst.ts",
    "demo:warm-start": "pnpm --filter @agentharbor/control-node exec tsx scripts/demo-warm-start.ts",
    "lint": "pnpm -r --filter './packages/**' --filter './apps/**' lint",
    "test:control": "pnpm --filter @agentharbor/control-node test",
    "typecheck": "pnpm -r --filter './packages/**' --filter './apps/**' typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  }
}
